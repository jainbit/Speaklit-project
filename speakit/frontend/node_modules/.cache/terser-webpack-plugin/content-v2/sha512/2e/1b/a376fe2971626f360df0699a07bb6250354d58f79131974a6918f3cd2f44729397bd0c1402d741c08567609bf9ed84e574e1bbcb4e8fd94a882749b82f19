AAG,CAAAtB,QAAA,eAC7CC,0BAAA,WAAQjD,KAAK,CAAC,GAAG,CAAAgD,QAAA,CAAC,eAAa,CAAQ,CAAC,cACxCC,0BAAA,WAAQjD,KAAK,CAAC,GAAG,CAAAgD,QAAA,CAAC,UAAQ,CAAQ,CAAC,cACnCC,0BAAA,WAAQjD,KAAK,CAAC,GAAG,CAAAgD,QAAA,CAAC,UAAQ,CAAQ,CAAC,cACnCC,0BAAA,WAAQjD,KAAK,CAAC,GAAG,CAAAgD,QAAA,CAAC,gBAAc,CAAQ,CAAC,cACzCC,0BAAA,WAAQjD,KAAK,CAAC,GAAG,CAAAgD,QAAA,CAAC,UAAQ,CAAQ,CAAC,EAC7B,CAAC,EACJ,CAAC,cACRF,2BAAA,UAAOC,SAAS,CAAC,aAAa,CAAAC,QAAA,EAAC,UAE7B,cAAAC,0BAAA,aAAUF,SAAS,CAAC,WAAW,CAACwB,IAAI,CAAE,CAAE,CAACZ,WAAW,CAAC,0BAA0B,CAAE,CAAC,EAC7E,CAAC,cACRV,0BAAA,WAAQG,IAAI,CAAC,QAAQ,CAACL,SAAS,CAAC,gBAAgB,CAAAC,QAAA,CAAC,iBAEjD,CAAQ,CAAC,EACF,CAAC,EACP,CACN,EACM,CAAC,EACP,CAAC,CAEV,CAEenC,+CAAG,E;;;;;ACtWlB2D,mBAAQ,CAACC,MAAM,cACbxB,0BAAA,CAACyB,eAAK,CAACC,UAAU,EAAA3B,QAAA,cACfC,0BAAA,CAACpC,OAAG,GAAE,CAAC,CACS,CAAC,CACnB+D,QAAQ,CAACC,cAAc,CAAC,MAAM,CAChC,CAAC,C","file":"x","sourcesContent":["// extracted by mini-css-extract-plugin","import React, { useMemo, useState } from 'react';\n\ntype Page = 'home' | 'upload' | 'dashboard' | 'preview' | 'analytics' | 'profile';\n\ntype Project = {\n  id: number;\n  title: string;\n  sourceLanguage: string;\n  targetLanguages: string[];\n  status: 'pending' | 'processing' | 'completed';\n  stage: string;\n  transcriptAccuracy: number;\n  translationAccuracy: number;\n  dubbingQuality: number;\n  processingTime: number;\n};\n\nconst languages = [\n  { value: 'en', label: 'English' },\n  { value: 'fr', label: 'French' },\n  { value: 'es', label: 'Spanish' },\n  { value: 'de', label: 'German' },\n  { value: 'hi', label: 'Hindi' },\n  { value: 'ja', label: 'Japanese' },\n];\n\nconst sampleProjects: Project[] = [\n  {\n    id: 1,\n    title: 'Quarterly Product Demo',\n    sourceLanguage: 'English',\n    targetLanguages: ['French', 'Hindi'],\n    status: 'processing',\n    stage: 'Translating',\n    transcriptAccuracy: 92,\n    translationAccuracy: 88,\n    dubbingQuality: 84,\n    processingTime: 7,\n  },\n  {\n    id: 2,\n    title: 'Founder Welcome Video',\n    sourceLanguage: 'English',\n    targetLanguages: ['Spanish', 'German', 'Japanese'],\n    status: 'completed',\n    stage: 'Completed',\n    transcriptAccuracy: 95,\n    translationAccuracy: 91,\n    dubbingQuality: 89,\n    processingTime: 12,\n  },\n];\n\nfunction App(): JSX.Element {\n  const [page, setPage] = useState<Page>('home');\n  const [sourceLanguage, setSourceLanguage] = useState('en');\n  const [targetLanguages, setTargetLanguages] = useState<string[]>(['fr']);\n  const [selectedFileName, setSelectedFileName] = useState('No file selected');\n  const [selectedProjectId, setSelectedProjectId] = useState<number>(sampleProjects[0].id);\n\n  const selectedProject = useMemo(\n    () => sampleProjects.find((project) => project.id === selectedProjectId) || sampleProjects[0],\n    [selectedProjectId]\n  );\n\n  const toggleLanguage = (languageCode: string) => {\n    setTargetLanguages((current) =>\n      current.includes(languageCode)\n        ? current.filter((item) => item !== languageCode)\n        : [...current, languageCode]\n    );\n  };\n\n  const navItems: { id: Page; label: string }[] = [\n    { id: 'home', label: 'Home' },\n    { id: 'upload', label: 'Upload' },\n    { id: 'dashboard', label: 'Processing' },\n    { id: 'preview', label: 'Preview' },\n    { id: 'analytics', label: 'Analytics' },\n    { id: 'profile', label: 'Profile' },\n  ];\n\n  return (\n    <div className=\"app-shell\">\n      <header className=\"topbar\">\n        <div>\n          <p className=\"eyebrow\">AI-Powered Video Localization</p>\n          <h1>SpeakIt</h1>\n        </div>\n        <nav className=\"nav\">\n          {navItems.map((item) => (\n            <button\n              key={item.id}\n              className={page === item.id ? 'nav-button active' : 'nav-button'}\n              onClick={() => setPage(item.id)}\n              type=\"button\"\n            >\n              {item.label}\n            </button>\n          ))}\n        </nav>\n      </header>\n\n      <main className=\"main-grid\">\n        <section className=\"hero-card\">\n          <p className=\"kicker\">Break language barriers with AI</p>\n          <h2>Transcribe, translate, dub, and export localized videos in one workflow.</h2>\n          <p className=\"hero-copy\">\n            This frontend is now wired as a working React app, so `npm start` can launch properly on\n            port 3000. The backend pipeline and API wiring can be connected next.\n          </p>\n          <div className=\"hero-actions\">\n            <button type=\"button\" className=\"primary-button\" onClick={() => setPage('upload')}>\n              Start Localizing\n            </button>\n            <button type=\"button\" className=\"secondary-button\" onClick={() => setPage('dashboard')}>\n              View Demo Dashboard\n            </button>\n          </div>\n          <div className=\"feature-strip\">\n            <div className=\"feature-pill\">Transcribe</div>\n            <div className=\"feature-pill\">Translate</div>\n            <div className=\"feature-pill\">Dub</div>\n          </div>\n        </section>\n\n        <section className=\"panel-stack\">\n          <article className=\"panel\">\n            <h3>Upload</h3>\n            <p>Source: {languages.find((item) => item.value === sourceLanguage)?.label}</p>\n            <p>Targets: {targetLanguages.map((item) => languages.find((lang) => lang.value === item)?.label).join(', ')}</p>\n            <p>File: {selectedFileName}</p>\n          </article>\n          <article className=\"panel\">\n            <h3>Live Status</h3>\n            <p>{selectedProject.title}</p>\n            <p>{selectedProject.stage}</p>\n            <div className=\"progress-track\">\n              <div\n                className=\"progress-fill\"\n                style={{ width: `${selectedProject.status === 'completed' ? 100 : 68}%` }}\n              />\n            </div>\n          </article>\n        </section>\n      </main>\n\n      <section className=\"content-card\">\n        {page === 'home' && (\n          <div className=\"grid-two\">\n            <article className=\"panel\">\n              <h3>How it works</h3>\n              <ol className=\"steps\">\n                <li>Upload an English video and pick one or more target languages.</li>\n                <li>Run AVLA to extract audio, transcribe, translate, dub, and merge.</li>\n                <li>Preview the localized output, download the export, and review analytics.</li>\n              </ol>\n            </article>\n            <article className=\"panel\">\n              <h3>Supported language pairs</h3>\n              <ul className=\"plain-list\">\n                <li>English → French</li>\n                <li>English → Spanish</li>\n                <li>English → German</li>\n                <li>English → Hindi</li>\n                <li>English → Japanese</li>\n              </ul>\n            </article>\n          </div>\n        )}\n\n        {page === 'upload' && (\n          <div className=\"grid-two\">\n            <article className=\"panel\">\n              <h3>Upload Video</h3>\n              <label className=\"input-label\">\n                Video title\n                <input className=\"text-input\" placeholder=\"Launch announcement\" />\n              </label>\n              <label className=\"input-label\">\n                Source language\n                <select\n                  className=\"text-input\"\n                  value={sourceLanguage}\n                  onChange={(event) => setSourceLanguage(event.target.value)}\n                >\n                  {languages.map((language) => (\n                    <option key={language.value} value={language.value}>\n                      {language.label}\n                    </option>\n                  ))}\n                </select>\n              </label>\n              <div className=\"input-label\">\n                Target languages\n                <div className=\"chip-grid\">\n                  {languages\n                    .filter((language) => language.value !== 'en')\n                    .map((language) => (\n                      <button\n                        key={language.value}\n                        type=\"button\"\n                        className={targetLanguages.includes(language.value) ? 'chip active' : 'chip'}\n                        onClick={() => toggleLanguage(language.value)}\n                      >\n                        {language.label}\n                      </button>\n                    ))}\n                </div>\n              </div>\n              <label className=\"upload-box\">\n                <input\n                  type=\"file\"\n                  accept=\"video/mp4,video/quicktime,video/x-matroska\"\n                  onChange={(event) =>\n                    setSelectedFileName(event.target.files?.[0]?.name || 'No file selected')\n                  }\n                />\n                <span>Drag a video here or click to browse</span>\n                <strong>{selectedFileName}</strong>\n              </label>\n              <button type=\"button\" className=\"primary-button\">\n                Start Processing\n              </button>\n            </article>\n            <article className=\"panel\">\n              <h3>What happens next</h3>\n              <ul className=\"plain-list\">\n                <li>Audio extraction with MoviePy + FFmpeg</li>\n                <li>Speech-to-text with Whisper</li>\n                <li>Translation with MarianMT</li>\n                <li>Dubbing with gTTS or Coqui TTS</li>\n                <li>Final merge and export</li>\n              </ul>\n            </article>\n          </div>\n        )}\n\n        {page === 'dashboard' && (\n          <div className=\"grid-two\">\n            <article className=\"panel\">\n              <h3>Your Projects</h3>\n              <div className=\"project-list\">\n                {sampleProjects.map((project) => (\n                  <button\n                    key={project.id}\n                    type=\"button\"\n                    className={selectedProjectId === project.id ? 'project-card active' : 'project-card'}\n                    onClick={() => setSelectedProjectId(project.id)}\n                  >\n                    <strong>{project.title}</strong>\n                    <span>{project.status.toUpperCase()}</span>\n                    <span>{project.stage}</span>\n                  </button>\n                ))}\n              </div>\n            </article>\n            <article className=\"panel\">\n              <h3>Pipeline Stages</h3>\n              <ul className=\"plain-list\">\n                <li>Extracting Audio</li>\n                <li>Transcribing</li>\n                <li>Translating</li>\n                <li>Dubbing</li>\n                <li>Merging</li>\n              </ul>\n              <div className=\"log-box\">\n                <p>[00:01] Upload received and queued.</p>\n                <p>[00:08] Whisper base model started.</p>\n                <p>[00:22] MarianMT translating 2 segments.</p>\n                <p>[00:37] gTTS dubbing in progress.</p>\n              </div>\n            </article>\n          </div>\n        )}\n\n        {page === 'preview' && (\n          <div className=\"grid-two\">\n            <article className=\"panel\">\n              <h3>Preview & Export</h3>\n              <div className=\"video-placeholder\">Original / Localized Player Area</div>\n              <button type=\"button\" className=\"primary-button\">\n                Download Localized Video\n              </button>\n            </article>\n            <article className=\"panel\">\n              <h3>Transcript</h3>\n              <p>\n                Welcome to SpeakIt. This is a placeholder transcript area that will later show timed\n                segments returned by Whisper.\n              </p>\n            </article>\n          </div>\n        )}\n\n